# Database — Neon Postgres (Mumbai region)
# Pooled connection for app queries
DATABASE_URL="postgresql://user:password@host.neon.tech:5432/ruthva?sslmode=require&connect_timeout=15"
# Direct connection for migrations
DIRECT_URL="postgresql://user:password@host.neon.tech:5432/ruthva?sslmode=require&connect_timeout=15"

# Auth.js
AUTH_SECRET="generate-with-npx-auth-secret"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Resend — Email OTP
RESEND_API_KEY="re_xxxxxxxxxx"

# WhatsApp — Meta Cloud API (commented out — using Gupshup)
# WHATSAPP_ACCESS_TOKEN="your-meta-access-token"
# WHATSAPP_PHONE_NUMBER_ID="your-phone-number-id"
# WHATSAPP_APP_SECRET="your-meta-app-secret"
# WHATSAPP_VERIFY_TOKEN="your-webhook-verify-token"

# Gupshup — WhatsApp Business API
GUPSHUP_API_KEY="your-gupshup-api-key"
GUPSHUP_SOURCE_NUMBER="your-source-phone-number"
GUPSHUP_APP_NAME="your-gupshup-app-name"
GUPSHUP_TEMPLATE_ADHERENCE="template-id-for-adherence-check"
GUPSHUP_TEMPLATE_REMINDER="template-id-for-pre-visit-reminder"
GUPSHUP_TEMPLATE_RECOVERY_1="template-id-for-recovery-1"
GUPSHUP_TEMPLATE_RECOVERY_2="template-id-for-recovery-2"
# GUPSHUP_WEBHOOK_SECRET="optional-shared-secret-for-webhook"

# Cron — Secret for authenticating cron requests
CRON_SECRET="generate-a-random-secret"

# Admin Dashboard — comma-separated list of admin email(s)
ADMIN_EMAIL="prabu@paretoid.com"

# Upstash Redis — Rate limiting
UPSTASH_REDIS_REST_URL="https://your-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"
