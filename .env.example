# Database — Neon Postgres (Mumbai region)
# Pooled connection for app queries
DATABASE_URL="postgresql://user:password@host.neon.tech:5432/ruthva?sslmode=require&connect_timeout=15"
# Direct connection for migrations
DIRECT_URL="postgresql://user:password@host.neon.tech:5432/ruthva?sslmode=require&connect_timeout=15"

# Auth.js
AUTH_SECRET="generate-with-npx-auth-secret"
AUTH_URL="http://localhost:3000"

# Resend — Email OTP
RESEND_API_KEY="re_xxxxxxxxxx"

# Gupshup — WhatsApp Business API
GUPSHUP_API_KEY="your-gupshup-api-key"
GUPSHUP_APP_NAME="ruthva"
GUPSHUP_APP_ID="your-gupshup-app-id"
GUPSHUP_WEBHOOK_SECRET="your-webhook-secret-for-hmac"

# Cron — Secret for authenticating cron requests
CRON_SECRET="generate-a-random-secret"

# Upstash Redis — Rate limiting
UPSTASH_REDIS_REST_URL="https://your-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"
